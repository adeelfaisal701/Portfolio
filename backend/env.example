# Optional: copy to backend/.env. MONGODB_URI lives in project root .env.local (never commit).

PORT=4000

# Omit or use * = any origin can call this public reviews API (needed for production domains).
# Or restrict: CORS_ORIGIN=https://yoursite.com,http://localhost:3000

# Max reviews returned by GET /reviews (default 1000, max 10000)
# REVIEWS_LIST_LIMIT=1000
